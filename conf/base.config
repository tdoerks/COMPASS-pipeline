/*
 * -------------------------------------------------
 *  Base Nextflow config file
 * -------------------------------------------------
 * This config file defines default resource requirements
 * and container settings used across all profiles.
 */

process {
    // Default resource requirements
    cpus = 1
    memory = '2.GB'
    time = '1h'

    // Process-specific resource requirements
    withName: 'AMRFINDER' {
        cpus = 4
        memory = '8.GB'
        time = '1h'
        errorStrategy = 'ignore'
    }

    withName: 'VIBRANT' {
        cpus = 8
        memory = '16.GB'
        time = '12h'
        errorStrategy = 'ignore'
    }

    withName: 'DIAMOND_PROPHAGE' {
        cpus = 4
        memory = '8.GB'
        time = '1h'
        errorStrategy = 'ignore'
    }

    withName: 'CHECKV' {
        cpus = 2
        memory = '8.GB'
        time = '2h'
        errorStrategy = 'ignore'
    }

    withName: 'PHANOTATE' {
        cpus = 2
        memory = '4.GB'
        time = '2h'
        errorStrategy = 'ignore'
    }

    withName: 'DOWNLOAD_NARMS_METADATA' {
        cpus = 1
        memory = '2.GB'
    }

    withName: 'FILTER_NARMS_SAMPLES' {
        cpus = 1
        memory = '4.GB'
    }

    withName: 'DOWNLOAD_SRA' {
        cpus = 4
        memory = '8.GB'
        time = '2h'
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
        maxRetries = 2
    }

    withName: 'FASTQC' {
        cpus = 2
        memory = '2.GB'
        time = '30m'
        errorStrategy = 'ignore'
    }

    withName: 'FASTP' {
        cpus = 4
        memory = '4.GB'
        time = '1h'
        errorStrategy = 'ignore'
    }

    withName: 'ASSEMBLE_SPADES' {
        cpus = 8
        memory = '32.GB'
        time = '12h'
        errorStrategy = 'ignore'       // Skip bad samples, don't crash pipeline
    }

    withName: 'BUSCO' {
        cpus = 4
        memory = '8.GB'
        time = '2h'
    }

    withName: 'DOWNLOAD_BUSCO_LINEAGE' {
        cpus = 1
        memory = '4.GB'
        time = '1h'
    }

    withName: 'MLST' {
        cpus = 2
        memory = '2.GB'
        time = '30m'
        errorStrategy = 'ignore'
    }

    withName: 'MOBSUITE_RECON' {
        cpus = 4
        memory = '8.GB'
        time = '1h'
        errorStrategy = 'ignore'
    }

    withName: 'SISTR' {
        cpus = 2
        memory = '4.GB'
        time = '30m'
        errorStrategy = 'ignore'
    }

    withName: 'MULTIQC' {
        cpus = 1
        memory = '4.GB'
        time = '30m'
    }

    withName: 'ABRICATE' {
        cpus = 1
        memory = '2.GB'
        time = '15m'
        errorStrategy = 'ignore'
    }

    withName: 'ABRICATE_SUMMARY' {
        cpus = 1
        memory = '2.GB'
        time = '15m'
    }

    withName: 'QUAST' {
        cpus = 2
        memory = '4.GB'
        time = '30m'
        errorStrategy = 'ignore'
    }
}

// Apptainer/Singularity configuration (used by most HPC environments)
apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "$HOME/.apptainer/cache"
}
