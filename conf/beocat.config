/*
 * -------------------------------------------------
 *  Beocat HPC cluster config
 * -------------------------------------------------
 * Configuration for Kansas State University's Beocat cluster
 * https://www.k-state.edu/hpc/
 */

process {
    executor = 'slurm'
    queue = 'batch.q'
    clusterOptions = { "${params.clusterOptions ?: ''}" }
}

// Cluster-specific parameters
params {
    // Database paths on Beocat
    max_memory = 100.GB
    max_cpus = 32
    max_time = 1.d
    clusterOptions = "--gres=killable:0"
}

// Additional settings for SLURM
// Optimized for large datasets (thousands of samples)
// UPDATED: Reduced queue pressure to prevent "Unexpected message received" errors
executor {
    queueSize = 300              // Max jobs in queue at once (reduced from 500 to prevent SLURM overload)
    submitRateLimit = '10/1min'  // Submit max 10 jobs per minute (reduced from 20 to prevent sbatch flooding)
    pollInterval = '45 sec'      // Check job status every 45 seconds (increased from 30s)
    queueStatInterval = '10 min' // Update queue statistics every 10 minutes (increased from 5min)
    exitReadTimeout = '120 sec'  // Wait up to 120 sec for exit status (increased from 60s)
}
