/*
 * -------------------------------------------------
 *  Beocat HPC cluster config
 * -------------------------------------------------
 * Configuration for Kansas State University's Beocat cluster
 * https://www.k-state.edu/hpc/
 */

process {
    executor = 'slurm'
    queue = 'batch.q'
    clusterOptions = { "${params.clusterOptions ?: ''}" }
}

// Cluster-specific parameters
params {
    // Database paths on Beocat
    max_memory = 100.GB
    max_cpus = 32
    max_time = 1.d
    clusterOptions = "--gres=killable:0"
}

// Additional settings for SLURM
// Optimized for large datasets (thousands of samples)
executor {
    queueSize = 500              // Max jobs in queue at once (increased from 100)
    submitRateLimit = '20/1min'  // Submit max 20 jobs per minute (prevent queue flooding)
    pollInterval = '30 sec'      // Check job status every 30 seconds
    queueStatInterval = '5 min'  // Update queue statistics every 5 minutes
    exitReadTimeout = '60 sec'   // Wait up to 60 sec for exit status
}
