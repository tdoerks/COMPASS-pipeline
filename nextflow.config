/*
 * -------------------------------------------------
 *  COMPASS Pipeline - Main Configuration
 * -------------------------------------------------
 * Comprehensive Omics Analysis of Salmonella and Phages
 */

// Pipeline parameters
params {
    // Input/output
    input = "samplesheet.csv"
    outdir = "results"

    // Metadata filtering parameters
    bioproject = null             // BioProject ID(s) - comma-separated (e.g., "PRJNA292661,PRJNA292663") or leave null for NARMS defaults
    species = null                // Species filter (e.g., "Salmonella", "Listeria") - filters across all SRA
    all_bacterial = false         // Download all bacterial samples from SRA (use with caution)
    filter_platform = "ILLUMINA"  // Sequencing platform filter (ILLUMINA only - pipeline designed for short reads)
    filter_library_source = "GENOMIC"  // Library source filter (GENOMIC = pure isolates, excludes metagenomic/environmental samples)
    filter_state = null           // State code (e.g., "KS", "CA", "TX")
    filter_year_start = null      // Minimum year (e.g., 2020)
    filter_year_end = null        // Maximum year (e.g., 2023)
    filter_source = null          // Source pattern (e.g., "chicken", "clinical")
    max_samples = 10000           // Maximum number of samples to process after filtering

    // AMR parameters
    amrfinder_db = ""
    abricate_dbs = "ncbi,card,resfinder,argannot"  // Comma-separated list of databases
    abricate_minid = 75                             // Minimum percent identity
    abricate_mincov = 50                            // Minimum percent coverage

    // Phage parameters
    prophage_db = ""                        // Path to prophage database (Diamond format .dmnd file)
    prophage_metadata = ""                  // Path to prophage metadata file (Excel format)

    // BUSCO parameters
    skip_busco = false                      // Skip BUSCO analysis (set to true if database not available)
    busco_auto_lineage = true               // Use auto-lineage mode to automatically select best prokaryotic lineage
    busco_lineage = "bacteria_odb10"       // BUSCO lineage dataset (used only if auto_lineage = false)
    busco_mode = "genome"                   // BUSCO mode (genome, proteins, transcriptome)
    busco_download_path = ""                // Path for BUSCO lineage datasets (e.g., /path/to/busco_downloads)

    // BUSCO QC parameters (contamination detection)
    busco_qc_max_duplicated = 5.0           // Maximum % duplicated BUSCOs (contamination threshold)
    busco_qc_min_complete = 80.0            // Minimum % complete BUSCOs (quality threshold)
    busco_qc_max_fragmented = 10.0          // Maximum % fragmented BUSCOs (fragmentation threshold)
    busco_qc_max_missing = 20.0             // Maximum % missing BUSCOs
    skip_busco_qc = false                   // Skip BUSCO QC (not recommended for production)
    busco_error_strategy = 'ignore'         // How to handle BUSCO QC failures: 'ignore' (skip), 'retry', 'terminate'

    // QUAST parameters
    quast_min_contig = 500                  // Minimum contig length to include in stats

    // Assembly QC parameters
    assembly_qc_min_contigs = 1             // Minimum number of contigs
    assembly_qc_max_contigs = 1000          // Maximum number of contigs (fragmentation check)
    assembly_qc_min_length = 1000000        // Minimum total assembly length (1 Mb)
    assembly_qc_min_n50 = 10000             // Minimum N50 value (10 kb)
    assembly_qc_max_n_pct = 5.0             // Maximum percentage of N bases
    skip_assembly_qc = false                // Skip assembly QC (not recommended for production)
    assembly_error_strategy = 'ignore'      // How to handle assembly failures: 'ignore' (skip), 'retry', 'terminate'

    // Read QC parameters (pre-assembly quality filtering)
    read_qc_min_reads = 100000              // Minimum reads after filtering (100K)
    read_qc_min_bases = 50000000            // Minimum bases after filtering (50 Mbp)
    read_qc_min_q30_rate = 0.7              // Minimum Q30 rate (70% bases Q30+)
    read_qc_min_survival = 0.3              // Minimum read survival rate after trimming (30%)
    skip_read_qc = false                    // Skip read QC filtering (not recommended for production)

    // Resource limits (overridden by profile configs)
    max_cpus = 16
    max_memory = '128.GB'
    max_time = '240.h'

    // Email notifications
    email = null                            // Email address for notifications (optional)
}

// Load base configuration for all profiles
includeConfig 'conf/base.config'

// Profile definitions
profiles {
    standard {
        // Standard profile for local execution
        process.executor = 'local'
    }

    beocat {
        // Kansas State University's Beocat cluster
        includeConfig 'conf/beocat.config'
    }

    ceres {
        // USDA ARS SCINet Ceres cluster
        includeConfig 'conf/ceres.config'
    }

    test {
        // Quick test profile with minimal resources
        process.executor = 'local'
        params.input = "test_samplesheet.csv"
        params.outdir = "test_results"
    }
}

// Manifest
manifest {
    name = 'COMPASS-pipeline'
    author = 'Tyler Doerks'
    description = 'Comprehensive Omics Analysis of Salmonella and Phages'
    mainScript = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version = '1.0.0'
}

// Apptainer/Singularity configuration
apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "$HOME/.apptainer/cache"
    pullTimeout = '60 min'  // Increase timeout for large containers like BUSCO
    //runOptions = '--no-home --contain --bind /homes/tylerdoe/databases:/homes/tylerdoe/databases'  // Fix userid resolution issue on fastscratch, bind databases
}

// Email notifications (only enabled if --email parameter is provided)
notification {
    enabled = params.email ? true : false
    to = params.email ?: ''
    from = 'noreply@beocat.ksu.edu'
}

// Execution report and timeline
report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}

// Function to ensure that resource requirements don't go beyond a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
