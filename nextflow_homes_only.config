// Temporary config override for /homes-only execution
// Workaround for /fastscratch stale file handle issue

// Disable auto-mounting to avoid trying to mount broken /fastscratch
apptainer {
    enabled = true
    autoMounts = false  // DISABLE auto-mount to avoid /fastscratch
    cacheDir = "$HOME/.apptainer/cache"
    pullTimeout = '60 min'
    // Explicitly tell Apptainer to NOT mount /fastscratch
    runOptions = '--no-mount /fastscratch --bind /homes/tylerdoe/databases:/homes/tylerdoe/databases --bind /homes/tylerdoe:/homes/tylerdoe'
}
